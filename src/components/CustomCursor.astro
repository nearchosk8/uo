---
// Custom cursor: a small NEUTRAL GREY circle that follows the pointer, replacing
// the native arrow for mouse users only. Its ink flips between var(--fg) (over
// the page surface) and var(--on-panel) (over an inverted [data-invert] panel)
// so it always contrasts — in all three themes. pointer-events:none keeps links
// clickable.
---
<div id="uo-cursor" aria-hidden="true"></div>

<style>
  #uo-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    /* theme-aware ink, flipped by JS over inverted surfaces; ~0.6 alpha */
    --cursor-ink: var(--fg);
    background-color: color-mix(in srgb, var(--cursor-ink) 60%, transparent);
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    transform: translate(-50%, -50%);
    transition: background-color 150ms ease;
  }
</style>

<script>
  const el = document.getElementById("uo-cursor");
  const fine = window.matchMedia("(pointer: fine)").matches;

  if (el && fine) {
    document.documentElement.classList.add("has-custom-cursor");

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // latest pointer position vs. the eased position the circle is drawn at
    let tx = 0, ty = 0;     // target
    let cx = 0, cy = 0;     // current
    let started = false;

    function draw(x, y) {
      el.style.transform = `translate(${x}px, ${y}px) translate(-50%,-50%)`;
    }

    // Flip the ink to --on-panel when the surface under the circle is an
    // inverted panel, else --fg. Guard against null (cursor off-window).
    function updateInk(x, y) {
      const under = document.elementFromPoint(x, y);
      const invert = under && under.closest("[data-invert]");
      el.style.setProperty("--cursor-ink", invert ? "var(--on-panel)" : "var(--fg)");
    }

    document.addEventListener("mousemove", (e) => {
      tx = e.clientX;
      ty = e.clientY;
      if (!started) {
        // snap to first position so it doesn't fly in from the corner
        started = true;
        cx = tx; cy = ty;
        draw(cx, cy);
      }
      if (reduce) { draw(tx, ty); updateInk(tx, ty); }
    });

    if (!reduce) {
      const lerp = (a, b, t) => a + (b - a) * t;
      function tick() {
        cx = lerp(cx, tx, 0.2);
        cy = lerp(cy, ty, 0.2);
        draw(cx, cy);
        updateInk(cx, cy);
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    // hide when the pointer leaves the window, show on return
    document.addEventListener("mouseleave", () => { el.style.opacity = "0"; });
    document.addEventListener("mouseenter", () => { el.style.opacity = ""; });
  }
</script>
