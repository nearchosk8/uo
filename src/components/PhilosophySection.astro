---
import Figure from "./Figure.astro";
import Reveal from "./Reveal.astro";
import philosophy1 from "../assets/philosophy-1.jpeg";
import philosophy2 from "../assets/philosophy-2.jpeg";
// Inverted rounded panel. The two images intentionally spill below the panel's
// bottom edge onto the page surface (signature detail in the comp). The black
// region height is a tunable var (--panel-h) — easy to nudge when iterating.
---
<section class="philosophy edge" style="--panel-h: clamp(28rem, 48vw, 42rem)">
  <!-- The inverted black block as a REAL element (not ::before) so the cursor
       can detect the surface via elementFromPoint/[data-invert]. -->
  <div class="ph-panel" data-invert aria-hidden="true"></div>
  <div class="ph-head" data-invert>
    <Reveal as="h2" class="h-display">
      <span class="u-line">Philosophy</span>
    </Reveal>
    <span class="idx">(2)</span>
  </div>
  <Reveal as="p" class="copy" data-invert>
    We approach every project from scratch, with a deep focus on detail, materials, and print.<br />
    From paper selection to final production, our work reflects a dedication to craft and thoughtful design.
  </Reveal>

  <div class="ph-images">
    <Figure
      label="philosophy"
      index="1/3"
      ext=".jpeg"
      ratio="1 / 1"
      image={philosophy1}
      alt="Printed Photo Diary book at the studio"
    />
    <Figure
      label="office"
      index="1/3"
      ext=".jpeg"
      ratio="4 / 5"
      image={philosophy2}
      alt="Selecting Pantone colors at the studio"
    />
  </div>
</section>

<style>
  .philosophy {
    position: relative;
    background: var(--bg);
    color: var(--on-panel);
    padding-top: clamp(2.5rem, 6vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }
  /* the inverted block sitting behind heading/copy and the top of the images.
     A real element (kept behind content at z-index 0) so it's hit-testable by
     elementFromPoint for the cursor's surface detection. */
  .philosophy > .ph-panel {
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: var(--panel-h);
    background: var(--panel);
    border-radius: clamp(18px, 1.8vw, 30px) clamp(18px, 1.8vw, 30px) 0 0;
    z-index: 0;
  }
  .philosophy > * { position: relative; z-index: 1; }

  .ph-head { display: flex; justify-content: space-between; align-items: baseline; gap: 2rem; }
  .h-display {
    font-family: var(--ff-display);
    font-weight: 500; /* display cut ships 500/700 only */
    font-size: clamp(2.6rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
  }
  /* ~0.75em of the heading clamp(2.6rem, 7vw, 6rem), to match About's "(1)" */
  .idx { font-family: var(--ff-display); font-weight: 500; font-size: clamp(1.95rem, 5.25vw, 4.5rem); line-height: 1; }
  .copy {
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.4;
    max-width: 62ch;
    margin: clamp(1.2rem, 2.5vw, 2rem) 0 0;
  }
  .ph-images {
    display: grid;
    /* 48% left square + 38.4% (= 48% × 0.8) right 4/5 portrait → same height;
       trailing 1fr is empty so the page background shows to the right. */
    grid-template-columns: 48% 38.4% 1fr;
    gap: clamp(1rem, 2.5vw, 2.2rem);
    margin-top: clamp(2.5rem, 6vw, 5rem);
    /* caption text below images sits on page bg, so reset to --fg */
    color: var(--fg);
  }
  @media (max-width: 720px) {
    .philosophy { --panel-h: clamp(18rem, 64vw, 30rem); }
    .ph-images { grid-template-columns: 1fr; }
  }
</style>
