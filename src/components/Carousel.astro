---
// Reusable image carousel: 3+ crossfading slides in an aspect-ratio box, an
// Instagram-story progress bar (4s fill -> auto-advance), and a centered caption
// row (leftLabel · (i/n) · ext). The bar's animationend advances + restarts the
// fill, keeping them in lockstep. Pauses on hover; no auto-advance under reduced
// motion. MULTI-INSTANCE safe — the script loops every [data-carousel] root.
// Props: slides [{img, alt}], leftLabel, ext, ratio (e.g. "1 / 1").
import { Image } from "astro:assets";
const { slides = [], leftLabel = "", ext = "", ratio = "1 / 1" } = Astro.props;
const total = slides.length;
---

<div class="carousel" data-carousel style={`--stage-ratio:${ratio}`}>
  <div class="stage">
    {slides.map((s, i) => (
      <Image src={s.img} alt={s.alt} class="slide" data-slide data-active={String(i === 0)} />
    ))}
  </div>

  <div class="controls mono">
    <div class="progress"><span class="fill" data-fill></span></div>
    <div class="controls-row">
      <span class="cap-label">{leftLabel}</span>
      <span class="counter" data-counter>(1/{total})</span>
      <span class="cap-label">{ext}</span>
    </div>
  </div>
</div>

<style>
  .carousel { width: 100%; }

  /* aspect-ratio box (per-instance via --stage-ratio); slides cover it */
  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: var(--stage-ratio, 1 / 1);
    overflow: hidden;
  }
  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms ease;
  }
  .slide[data-active="true"] { opacity: 1; pointer-events: auto; }

  .controls { margin-top: 0.6rem; color: var(--fg); }

  /* thin full-width track; .fill scales left->right like an Instagram story bar */
  .progress {
    position: relative;
    width: 100%;
    height: 2px;
    background: color-mix(in srgb, currentColor 20%, transparent);
    overflow: hidden;
  }
  .fill {
    position: absolute;
    inset: 0;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
  }
  .fill.run { animation: story-fill 4s linear forwards; }
  /* pause the fill (and thus the animationend-driven advance) on hover */
  .carousel:hover .fill.run { animation-play-state: paused; }
  @keyframes story-fill {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  /* caption row: leftLabel (left) · (i/n) (center) · ext (right). 1fr/auto/1fr
     keeps the counter truly centered regardless of the side labels' widths. */
  .controls-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    margin-top: 0.6rem;
  }
  .controls-row > :first-child { text-align: left; }
  .controls-row > .counter { text-align: center; }
  .controls-row > :last-child { text-align: right; }

  .counter,
  .cap-label { color: var(--fg); }
</style>

<script>
  // Drive EVERY carousel independently (multi-instance safe).
  document.querySelectorAll("[data-carousel]").forEach((root) => {
    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const fill = root.querySelector("[data-fill]");
    const counter = root.querySelector("[data-counter]");
    const n = slides.length;
    if (!n) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let i = 0;
    function render() {
      slides.forEach((s, k) => s.setAttribute("data-active", String(k === i)));
      if (counter) counter.textContent = `(${i + 1}/${n})`;
    }
    function go(k) { i = (k + n) % n; render(); }

    // (Re)start the 4s fill from 0. Under reduced-motion it stays static (no
    // animation, no animationend) so this carousel doesn't auto-advance.
    function restartFill() {
      if (!(fill instanceof HTMLElement)) return;
      fill.classList.remove("run");
      void fill.offsetWidth; // force reflow so the animation can replay
      if (!reduce) fill.classList.add("run");
    }

    // The fill reaching 100% advances the slide — bar + advance stay in sync.
    fill?.addEventListener("animationend", () => { go(i + 1); restartFill(); });

    render();
    restartFill();
  });
</script>
