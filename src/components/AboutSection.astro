---
import Figure from "./Figure.astro";
import office1 from "../assets/office-1.jpeg";
---
<section class="about edge">
  <div class="about-text">
    <h1 class="h-display">
      <span class="u-link">About</span> <span class="u-link">us</span>
      <span class="idx">(1)</span>
    </h1>

    <p class="mono label">About Us</p>
    <p class="lede">
      Founded in 2020 in Athens, Greece.<br />
      Our ambition is not to use a title for our office<br />
      because our work speaks itself and no descriptions needed.
    </p>
    <p class="lede">
      <span class="u-link">The language is visual</span> &amp;
      <span class="u-link">you have the vision and we add the title.</span>
    </p>
    <p class="lede">
      <a class="u-link" href="#" data-placeholder>Want to see what we mean? Explore recent works</a>
    </p>
  </div>

  <div class="about-img">
    <Figure
      label="office"
      index="1/3"
      ext=".jpeg"
      ratio="3 / 4"
      image={office1}
      alt="Untitled Office — reviewing printed work in the studio"
    />
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
    padding-top: clamp(1rem, 3vw, 3rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }
  .h-display {
    font-weight: 400;
    font-size: clamp(2.6rem, 6.5vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 0 0 clamp(1.4rem, 3vw, 2.4rem);
    position: relative;
  }
  .h-display .idx { font-size: 0.75em; vertical-align: baseline; margin-left: 0.4em; letter-spacing: -0.02em; }
  .label { margin: 0 0 0.5rem; }
  .lede {
    font-size: clamp(0.95rem, 1.15vw, 1.1rem);
    line-height: 1.4;
    margin: 0 0 1.4rem;
    max-width: 40ch;
  }
  .about-img { justify-self: end; width: 100%; }

  @media (max-width: 820px) {
    .about { grid-template-columns: 1fr; }
    .about-img { order: -1; }
    .h-display { font-size: clamp(3rem, 13vw, 4.5rem); }
  }
</style>
