---
import Carousel from "./Carousel.astro";
import Reveal from "./Reveal.astro";
import office1 from "../assets/office-1.jpeg";
import office2 from "../assets/office-2.jpeg";
import office3 from "../assets/office-3.jpeg";

const aboutSlides = [
  { img: office1, alt: "Untitled Office — reviewing printed work in the studio" },
  { img: office2, alt: "Untitled Office — inside the studio" },
  { img: office3, alt: "Untitled Office — studio work in progress" },
];
---
<section class="about edge">
  <div class="about-text">
    <Reveal as="h1" class="h-display">
      <span class="u-line">About us</span>
      <span class="idx">(1)</span>
    </Reveal>

    <div class="about-lede">
      <Reveal as="p" class="lede">
        Founded in 2020 in Athens, Greece.<br />
        Our ambition is not to use a title for our office<br />
        because our work speaks itself and no descriptions needed.
      </Reveal>
      <Reveal as="p" class="lede">
        <span class="u-link">The language is visual</span> &amp;
        <span class="u-link">you have the vision and we add the title.</span>
      </Reveal>
      <Reveal as="p" class="lede">
        <a class="u-link" href="#" data-placeholder>Want to see what we mean? Explore recent works</a>
      </Reveal>
    </div>
  </div>

  <div class="about-img">
    <Carousel slides={aboutSlides} leftLabel="office" ext=".jpeg" ratio="1 / 1" />
  </div>
</section>

<style>
  .about {
    display: grid;
    /* proportional split matching the artboard (image ≈ 874.62/1900 ≈ 46%) so the
       text/gap/image proportions stay identical at every width */
    grid-template-columns: 1fr 46%;
    gap: clamp(1.5rem, 4vw, 4rem);
    /* stretch so the text column matches the (taller) image's row height, letting
       the lede absolutely-center against the image while the heading stays on top */
    align-items: stretch;
    padding-top: clamp(1rem, 3vw, 3rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }
  .about-text { position: relative; }
  .about-lede {
    position: absolute;
    top: 50%; left: 0; right: 0;
    transform: translateY(-50%);
  }
  .h-display {
    font-family: var(--ff-display);
    font-weight: 500; /* display cut ships 500/700 only */
    font-size: clamp(2.6rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 clamp(1.4rem, 3vw, 2.4rem);
    position: relative;
  }
  .h-display .idx { font-size: 0.75em; vertical-align: baseline; margin-left: 0.4em; letter-spacing: -0.02em; }
  .lede {
    font-size: clamp(1rem, 1.74vw, 33px);
    line-height: 1.4;
    /* em-based so the gap between the three groups ≈ one blank line at any size */
    margin: 0 0 1.5em;
    /* break only at the authored <br>s — never auto-wrap into different rows */
    white-space: nowrap;
  }
  .about-img { justify-self: end; width: 100%; }

  @media (max-width: 820px) {
    .about { grid-template-columns: 1fr; align-items: start; }
    .about-img { order: -1; }
    /* phones can't fit the fixed lines — let the lede wrap normally, readable size */
    .lede { white-space: normal; font-size: clamp(1rem, 3.4vw, 1.25rem); }
    /* revert the desktop centering: normal stacked flow */
    .about-lede { position: static; transform: none; }
  }
</style>
