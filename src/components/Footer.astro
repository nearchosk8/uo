---
// Footer = inverted rounded panel (matches comp). Newsletter + "lets talk"
// are wired as non-submitting placeholders until the form/email service is
// chosen. Giant wordmark uses Neue Pixel Grotesk (the split-"U").
---
<footer class="foot">
  <div class="foot-panel panel edge">
    <div class="foot-grid">
      <div class="cta-left">
        <span class="mono label">Lets Talk</span>
        <p class="cta-h">
          <span class="u-link">Begin your</span><br />
          <span class="u-link">journey</span> <span class="u-link">Today</span>
        </p>
        <button class="pill" type="button" data-placeholder>
          <span class="pill-arrow" aria-hidden="true">→</span> lets talk
        </button>
      </div>

      <div class="socials mono">
        <a class="u-link" href="#">Instagram</a>
        <a class="u-link" href="#">LinkedIn</a>
        <a class="u-link" href="#">Bēhance</a>
      </div>

      <div class="cta-right">
        <p class="cta-h"><span class="u-link">Get in</span><br /><span class="u-link">touch</span></p>
        <div class="email-field">
          <input type="email" placeholder="Add your email" aria-label="Add your email" />
          <button type="button" class="email-go" aria-label="Submit email" data-placeholder>→</button>
        </div>
      </div>
    </div>

    <div class="foot-details">
      <div><span class="d-label">New journey</span><a class="d-val" href="mailto:hello@untitledoffice.gr">hello@untitledoffice.gr</a></div>
      <div><span class="d-label">Phone:</span><span class="d-val">(+30) 210 722 1043 | (+30) 6972737996</span></div>
      <div><span class="d-label">Contact</span><a class="d-val" href="mailto:info@untitledoffice.gr">info@untitledoffice.gr</a></div>
      <div><span class="d-label">Ath (Gr)</span><span class="d-val">Ippokratous 7, 106 79</span></div>
    </div>

    <hr class="rule" />
    <div class="bigmark" aria-hidden="true">Untitled Office</div>
  </div>
</footer>

<style>
  .foot { padding: 0 0 0; background: var(--bg); }
  .foot-panel {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    padding-top: clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  .label { display: block; margin-bottom: 0.6rem; color: var(--on-panel); }
  .cta-h {
    font-size: clamp(1.6rem, 2.8vw, 2.6rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 clamp(1rem, 2vw, 1.6rem);
  }
  .cta-right { justify-self: end; text-align: left; width: 100%; max-width: 22rem; }
  .socials { display: flex; gap: 1rem; justify-content: center; padding-top: 0.4rem; }

  .pill {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: color-mix(in srgb, var(--on-panel) 28%, transparent);
    color: var(--on-panel);
    border: 0; border-radius: 999px; cursor: pointer;
    padding: 0.5rem 1.1rem 0.5rem 0.5rem; font: inherit; font-size: 0.95rem;
  }
  .pill-arrow {
    display: inline-grid; place-items: center; width: 1.7rem; height: 1.7rem;
    background: var(--on-panel); color: var(--panel); border-radius: 50%;
  }
  .email-field { display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid var(--on-panel); padding-bottom: 0.5rem; }
  .email-field input { flex: 1; background: none; border: 0; color: var(--on-panel); font: inherit; font-size: 1rem; outline: none; }
  .email-field input::placeholder { color: color-mix(in srgb, var(--on-panel) 60%, transparent); }
  .email-go { background: none; border: 1px solid var(--on-panel); color: var(--on-panel); border-radius: 50%; width: 2rem; height: 2rem; cursor: pointer; }

  .foot-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 26rem));
    gap: 0.4rem clamp(2rem, 6vw, 6rem);
    margin-top: clamp(2.5rem, 6vw, 5rem);
  }
  .foot-details > div { display: grid; }
  .d-label { font-size: 0.85rem; }
  .d-val { font-size: 0.85rem; color: var(--muted); }

  .rule { border: 0; border-top: 1px solid var(--on-panel); margin: clamp(1.5rem, 3vw, 2.5rem) 0 0; opacity: 0.8; }
  .bigmark {
    font-family: var(--ff-sans);
    font-weight: 500;
    font-size: clamp(3.5rem, 17vw, 16rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin-top: clamp(0.5rem, 1.5vw, 1.2rem);
    white-space: nowrap;
    transform: translateY(8%);
  }

  @media (max-width: 820px) {
    .foot-grid { grid-template-columns: 1fr; }
    .socials { justify-content: flex-start; }
    .cta-right { justify-self: start; }
    .foot-details { grid-template-columns: 1fr; }
  }
</style>
