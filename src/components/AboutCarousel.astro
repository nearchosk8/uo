---
// About hero carousel: 3 crossfading square slides in the same aspect-ratio box
// the single Figure used, with an Instagram-story progress bar, a next arrow,
// and a counter. The bar fills left->right over 4s; its animationend advances to
// the next slide and restarts the fill, keeping bar + auto-advance in sync.
// Pauses on hover; no auto-advance under reduced-motion.
import { Image } from "astro:assets";
import office1 from "../assets/office-1.jpeg";
import office2 from "../assets/office-2.jpeg";
import office3 from "../assets/office-3.jpeg";

const slides = [
  { img: office1, alt: "Untitled Office — reviewing printed work in the studio" },
  { img: office2, alt: "Untitled Office — inside the studio" },
  { img: office3, alt: "Untitled Office — studio work in progress" },
];
---

<div class="carousel" data-carousel>
  <div class="stage">
    {slides.map((s, i) => (
      <Image src={s.img} alt={s.alt} class="slide" data-slide data-active={String(i === 0)} />
    ))}
  </div>

  <div class="controls mono">
    <div class="progress"><span class="fill" data-fill></span></div>
    <div class="controls-row">
      <span class="cap-label">office</span>
      <span class="counter" data-counter>(1/3)</span>
      <span class="cap-label">.jpeg</span>
    </div>
  </div>
</div>

<style>
  .carousel { width: 100%; }

  /* same aspect-ratio-box pattern as Figure: box holds the square, slides cover */
  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms ease;
  }
  .slide[data-active="true"] { opacity: 1; pointer-events: auto; }

  .controls { margin-top: 0.6rem; color: var(--fg); }

  /* thin full-width track; .fill scales left->right like an Instagram story bar */
  .progress {
    position: relative;
    width: 100%;
    height: 2px;
    background: color-mix(in srgb, currentColor 20%, transparent);
    overflow: hidden;
  }
  .fill {
    position: absolute;
    inset: 0;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
  }
  .fill.run { animation: story-fill 4s linear forwards; }
  /* pause the fill (and thus the animationend-driven advance) on hover */
  .carousel:hover .fill.run { animation-play-state: paused; }
  @keyframes story-fill {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  /* caption row: office (left) · (1/3) (center) · .jpeg (right). The 1fr/auto/1fr
     grid keeps the counter truly centered regardless of the side labels' widths. */
  .controls-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    margin-top: 0.6rem;
  }
  .controls-row > :first-child { text-align: left; }
  .controls-row > .counter { text-align: center; }
  .controls-row > :last-child { text-align: right; }

  .counter,
  .cap-label { color: var(--fg); }
</style>

<script>
  // Scope to this component's root; one instance on the page.
  const root = document.querySelector("[data-carousel]");
  if (root) {
    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const fill = root.querySelector("[data-fill]");
    const counter = root.querySelector("[data-counter]");
    const n = slides.length;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let i = 0;
    function render() {
      slides.forEach((s, k) => s.setAttribute("data-active", String(k === i)));
      if (counter) counter.textContent = `(${i + 1}/${n})`;
    }
    function go(k) { i = (k + n) % n; render(); }

    // (Re)start the 4s fill from 0. Under reduced-motion the bar stays static
    // (no animation, no animationend) so the carousel doesn't auto-advance.
    function restartFill() {
      if (!(fill instanceof HTMLElement)) return;
      fill.classList.remove("run");
      void fill.offsetWidth; // force reflow so the animation can replay
      if (!reduce) fill.classList.add("run");
    }

    // The fill reaching 100% is what advances the slide — bar + advance stay
    // in lockstep at 4s.
    fill?.addEventListener("animationend", () => { go(i + 1); restartFill(); });

    render();
    restartFill();
  }
</script>
