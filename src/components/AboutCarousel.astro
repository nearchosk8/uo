---
// About hero carousel: 3 crossfading square slides in the same aspect-ratio box
// the single Figure used, with a progress line, prev/next arrows, and a counter.
// Auto-advances every 5s (wraps), pauses on hover and under reduced-motion.
import { Image } from "astro:assets";
import office1 from "../assets/office-1.jpeg";
import office2 from "../assets/office-2.jpeg";
import office3 from "../assets/office-3.jpeg";

const slides = [
  { img: office1, alt: "Untitled Office — reviewing printed work in the studio" },
  { img: office2, alt: "Untitled Office — inside the studio" },
  { img: office3, alt: "Untitled Office — studio work in progress" },
];

// arrow.svg inlined so fill follows the theme via currentColor. The icon points
// RIGHT (used as-is for next; mirrored with scaleX(-1) for prev).
const arrowSvg = `<svg class="arrow" viewBox="0 0 874.62 874.62" aria-hidden="true"><path d="M437.31,40.61c-219.09,0-396.7,177.61-396.69,396.7,0,219.09,177.61,396.7,396.7,396.69,219.1,0,396.7-177.61,396.7-396.7,0-219.1-177.61-396.7-396.7-396.7M683.96,405.08v64.45s0,.19,0,.19c0,0-.02,0-.04,0h0s-.58,0-.58,0c-76.65,21.66-128.41,79.02-128.41,168.01,0,18.35,2.2,35.45,6.43,51.02h-55.67c-2.96-16.16-4.57-33.17-4.57-51.02,0-69.54,23.85-126.8,64.37-168.01H190.66s0-62.1,0-62.1h377.69c-.93-.92-1.92-1.78-2.84-2.72-40.52-41.2-64.37-98.47-64.37-168.02,0-17.85,1.6-34.86,4.57-51.02h55.67c-4.23,15.57-6.43,32.66-6.43,51.02,0,89,51.77,146.36,128.43,168.02.07.04.17.06.26.08.11-.03.22-.06.33-.09v.19Z"/></svg>`;
---

<div class="carousel" data-carousel>
  <div class="stage">
    {slides.map((s, i) => (
      <Image src={s.img} alt={s.alt} class="slide" data-slide data-active={String(i === 0)} />
    ))}
  </div>

  <div class="controls mono">
    <div class="progress"><span class="thumb" data-thumb></span></div>
    <div class="controls-row">
      <div class="nav">
        <button class="arrow-btn prev" type="button" aria-label="Previous image" data-prev>
          <Fragment set:html={arrowSvg} />
        </button>
        <button class="arrow-btn next" type="button" aria-label="Next image" data-next>
          <Fragment set:html={arrowSvg} />
        </button>
      </div>
      <span class="counter" data-counter>01/03</span>
    </div>
  </div>
</div>

<style>
  .carousel { width: 100%; }

  /* same aspect-ratio-box pattern as Figure: box holds the square, slides cover */
  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms ease;
  }
  .slide[data-active="true"] { opacity: 1; pointer-events: auto; }

  .controls { margin-top: 0.6rem; color: var(--fg); }

  /* thin full-width progress line with a 1/3-width thumb that slides per slide */
  .progress {
    position: relative;
    width: 100%;
    height: 2px;
    background: color-mix(in srgb, currentColor 20%, transparent);
    overflow: hidden;
  }
  .thumb {
    position: absolute;
    top: 0;
    left: 0;
    width: calc(100% / 3);
    height: 100%;
    background: currentColor;
    transform: translateX(0);
    transition: transform 500ms ease;
  }

  .controls-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.6rem;
  }
  .nav { display: inline-flex; gap: 0.6rem; }
  .arrow-btn {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: inherit;
    display: inline-grid;
    place-items: center;
  }
  .arrow-btn :global(.arrow) {
    width: 22px;
    height: 22px;
    fill: currentColor;
    display: block;
  }
  .prev :global(.arrow) { transform: scaleX(-1); }

  .counter { color: var(--fg); }
</style>

<script>
  // Scope to this component's root; one instance on the page.
  const root = document.querySelector("[data-carousel]");
  if (root) {
    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const thumb = root.querySelector("[data-thumb]");
    const counter = root.querySelector("[data-counter]");
    const prevBtn = root.querySelector("[data-prev]");
    const nextBtn = root.querySelector("[data-next]");
    const n = slides.length;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const pad = (x) => String(x).padStart(2, "0");

    let i = 0;
    function render() {
      slides.forEach((s, k) => s.setAttribute("data-active", String(k === i)));
      if (thumb instanceof HTMLElement) thumb.style.transform = `translateX(${i * 100}%)`;
      if (counter) counter.textContent = `${pad(i + 1)}/${pad(n)}`;
    }
    function go(k) { i = (k + n) % n; render(); }

    let timer = null;
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    function start() {
      if (reduce) return;
      stop();
      timer = setInterval(() => go(i + 1), 5000);
    }

    prevBtn?.addEventListener("click", () => { go(i - 1); start(); }); // manual resets timer
    nextBtn?.addEventListener("click", () => { go(i + 1); start(); });
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    render();
    start();
  }
</script>
