---
// Header: wordmark · menu trigger (···) · theme toggles + live Athens clock.
// NOTE: the design specifies one palette label + Local Time on the right.
// The light/dark control isn't placed in the comp, so I've added it as a
// discreet mono toggle beside the palette — flag for your friend to confirm.
import Logo from "./Logo.astro";
---

<header class="edge uo-header">
  <a href="/" class="wordmark" aria-label="Untitled Office — home"><Logo class="logo" /></a>

  <button id="menu-open" class="dots" aria-label="Open menu" aria-haspopup="true">
    <span></span><span></span><span></span>
  </button>

  <div class="controls mono">
    <button class="switch" type="button" role="switch" data-mode-toggle aria-label="Toggle light or dark theme">
      <span class="knob"></span>
    </button>
    <button class="switch switch--palette" type="button" role="switch" data-color-toggle aria-label="Toggle grayscale or orange palette">
      <span class="knob"></span>
    </button>
    <span class="clock">Local Time:&nbsp;<time id="clock">--:--</time></span>
  </div>
</header>

<style>
  .uo-header {
    position: relative;
    z-index: 30;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-block: clamp(1.1rem, 1.8vw, 1.6rem);
  }
  .wordmark {
    font-size: clamp(1.15rem, 1.5vw, 1.55rem);
    letter-spacing: -0.02em;
    justify-self: start;
    display: inline-flex; /* shrink-wrap the logo, no baseline gap */
  }
  /* logo height matches the wordmark text height; width follows the aspect ratio.
     :global so the rule reaches the <svg> rendered inside Logo.astro (otherwise
     Astro scopes it to Header and it never matches → svg collapses to 0 width). */
  .wordmark :global(.logo) {
    height: clamp(1.15rem, 1.5vw, 1.55rem);
    width: auto;
    display: block;
  }
  .dots {
    justify-self: center;
    display: inline-flex;
    gap: 4px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 10px;
  }
  .dots span {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--fg);
    display: block;
    transition: transform 200ms ease;
  }
  /* on hover/focus the outer two dots spread apart; the middle stays put */
  .dots:hover span:first-child,
  .dots:focus-visible span:first-child { transform: translateX(-4px); }
  .dots:hover span:last-child,
  .dots:focus-visible span:last-child { transform: translateX(4px); }
  .controls {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 1.6vw, 1.6rem);
  }
  /* iOS-style pill toggle switches (rem units so they scale with the proportional
     system). Knob slides right when aria-checked="true". */
  .switch {
    position: relative;
    flex: none;
    width: 2.6rem;
    height: 1.5rem;
    padding: 0;
    background: none;
    border: 1.5px solid var(--fg);
    border-radius: 999px;
    cursor: pointer;
  }
  .knob {
    position: absolute;
    top: 50%;
    left: 0.15rem;
    width: calc(1.5rem - 0.3rem - 3px); /* pill height − inset both sides − borders */
    height: calc(1.5rem - 0.3rem - 3px);
    border-radius: 50%;
    transform: translate(0, -50%);
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1);
    /* mode switch: solid ink knob (black on light, white on dark — always visible) */
    background: var(--fg);
  }
  /* palette switch: black track interior gives contrast for the borderless orange knob
     (so it stays visible even on the orange theme's orange page background) */
  .switch--palette { background: #000; }
  .switch--palette .knob {
    background: #ff7523;
    border: none;
  }
  /* checked → slide the knob to the right end (track − knob − both insets) */
  .switch[aria-checked="true"] .knob {
    transform: translate(calc(2.6rem - 100% - 0.3rem - 3px), -50%);
  }
  .clock { color: var(--fg); white-space: nowrap; }

  @media (max-width: 720px) {
    .uo-header { grid-template-columns: 1fr auto; row-gap: 0.4rem; }
    .dots { grid-column: 2; justify-self: end; }
    /* center the controls row in the band between the wordmark and the first
       image: space above is only the 0.4rem row-gap, space below is ~2.1rem
       (header padding-bottom 1.1rem + About padding-top ~1rem). Add the
       difference (~1.7rem) on top so the gaps above/below become equal. */
    .controls { grid-column: 1 / -1; justify-self: start; flex-wrap: wrap; gap: 0.7rem 1rem; margin-top: 1.7rem; }
  }
</style>

<script>
  const root = document.documentElement;
  function save(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
  const modeToggle = document.querySelector("[data-mode-toggle]");
  const colorToggle = document.querySelector("[data-color-toggle]");
  function sync() {
    const mode = root.getAttribute("data-mode");
    const color = root.getAttribute("data-color");
    modeToggle?.setAttribute("aria-checked", String(mode === "dark"));
    colorToggle?.setAttribute("aria-checked", String(color === "orange"));
  }
  modeToggle?.addEventListener("click", () => {
    const next = root.getAttribute("data-mode") === "dark" ? "light" : "dark";
    root.setAttribute("data-mode", next);
    save("uo-mode", next); sync();
  });
  colorToggle?.addEventListener("click", () => {
    const next = root.getAttribute("data-color") === "orange" ? "grayscale" : "orange";
    root.setAttribute("data-color", next);
    save("uo-color", next); sync();
  });
  sync();

  // Live local time in Athens (Europe/Athens), 24h, updates every second.
  const clock = document.getElementById("clock");
  function tick() {
    const t = new Intl.DateTimeFormat("en-GB", {
      hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false, timeZone: "Europe/Athens",
    }).format(new Date());
    if (clock) clock.textContent = t;
  }
  tick();
  setInterval(tick, 1000);
</script>
