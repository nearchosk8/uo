---
// Figure with the design's caption row: name · (index) · .ext
// When `image` (an Astro ImageMetadata) is supplied, renders an optimized
// <Image> filling the slot; otherwise falls back to the grey placeholder.
import { Image } from "astro:assets";
const { label = "office", index = "1/3", ext = ".jpeg", ratio = "1 / 1", image, alt = "" } = Astro.props;
---
<figure class="fig">
  <div class="ph" style={`aspect-ratio:${ratio}`}>
    {image
      ? <Image src={image} alt={alt} class="img" />
      : <span class="mono">PLACEHOLDER IMAGE</span>}
  </div>
  <figcaption class="reveal-on-scroll">
    <span class="reveal-inner">
      <span class="cap mono"><span>{label}</span><span>({index})</span><span>{ext}</span></span>
    </span>
  </figcaption>
</figure>

<style>
  /* min-width:0 lets the figure shrink to its grid track instead of blowing it
     out to the optimized image's large intrinsic width — so fr columns (and
     thus equal photo heights) are honored. */
  .fig { margin: 0; min-width: 0; }
  .ph {
    position: relative;
    width: 100%;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--fg) 8%, transparent);
    border: 1px solid var(--hairline);
    color: color-mix(in srgb, var(--fg) 40%, transparent);
  }
  /* Absolutely positioned so the image is out of flow and .ph's height comes
     purely from its inline aspect-ratio (the in-flow img otherwise forces its
     natural portrait height). */
  .ph .img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .cap { display: flex; justify-content: space-between; margin-top: 0.6rem; }
</style>
