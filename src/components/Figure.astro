---
// Figure with the design's caption row: name · (index) · .ext
// When `image` (an Astro ImageMetadata) is supplied, renders an optimized
// <Image> filling the slot; otherwise falls back to the grey placeholder.
import { Image } from "astro:assets";
const { label = "office", index = "1/3", ext = ".jpeg", ratio = "1 / 1", image, alt = "" } = Astro.props;
---
<figure class="fig">
  <div class="ph" style={`aspect-ratio:${ratio}`}>
    {image
      ? <Image src={image} alt={alt} class="img" />
      : <span class="mono">PLACEHOLDER IMAGE</span>}
  </div>
  <figcaption class="cap mono">
    <span>{label}</span><span>({index})</span><span>{ext}</span>
  </figcaption>
</figure>

<style>
  .fig { margin: 0; }
  .ph {
    width: 100%;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--fg) 8%, transparent);
    border: 1px solid var(--hairline);
    color: color-mix(in srgb, var(--fg) 40%, transparent);
  }
  .ph .img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cap { display: flex; justify-content: space-between; margin-top: 0.6rem; }
</style>
