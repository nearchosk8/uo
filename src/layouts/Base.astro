---
import "../styles/global.css";
import CustomCursor from "../components/CustomCursor.astro";
const { title = "Untitled Office — Design Office, Athens", description = "Untitled Office is a design office based in Athens, Greece, known for a systematic approach to design-driven projects across Brand, Print, Screen and Space." } = Astro.props;
---

<!doctype html>
<html lang="en" data-mode="light" data-color="grayscale">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Neue Haas Grotesk via Adobe Fonts (Typekit) kit. -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/yae3ppr.css" />
    <!-- Theme bootstrap: applies saved choice before paint to avoid a flash.
         Default is light + grayscale (per spec). localStorage is guarded so
         it degrades gracefully where storage is unavailable. -->
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem("uo-mode");
          var c = localStorage.getItem("uo-color");
          if (m) document.documentElement.setAttribute("data-mode", m);
          if (c) document.documentElement.setAttribute("data-color", c);
        } catch (e) {}
      })();
    </script>
    <!-- Mark JS-on BEFORE paint so the reveal pre-state (hidden) applies with no
         flash. With no JS this never runs → text stays visible. -->
    <script is:inline>
      document.documentElement.classList.add("js-reveal");
    </script>
  </head>
  <body>
    <CustomCursor />
    <slot />
  </body>
</html>

<script>
  // Masked slide-up reveal on first scroll into view (mirrors the burger nav).
  // Staggers siblings within their parent, reveals each element once.
  (function () {
    const els = Array.prototype.slice.call(
      document.querySelectorAll(".reveal-on-scroll")
    );
    if (!els.length) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce || !("IntersectionObserver" in window)) {
      els.forEach((el) => el.classList.add("revealed")); // show statically
      return;
    }

    // cascade: delay by index among reveal-siblings in the same parent
    els.forEach((el) => {
      const parent = el.parentElement;
      if (!parent) return;
      const sibs = Array.prototype.filter.call(parent.children, (c) =>
        c.classList && c.classList.contains("reveal-on-scroll")
      );
      const idx = sibs.indexOf(el);
      if (idx > 0) el.style.setProperty("--reveal-delay", idx * 80 + "ms");
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            io.unobserve(entry.target); // animate once
          }
        });
      },
      { threshold: 0.15 }
    );
    els.forEach((el) => io.observe(el));
  })();
</script>
